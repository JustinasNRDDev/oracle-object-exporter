# Python cache
**/__pycache__/
**/*.pyc
**/*.pyo

# Virtual environments
.venv/
**/.venv/

# Runtime outputs (do not commit)
**/logs/**
**/EXPORTED_OBJECTS/**

# Keep folder structure placeholders
!**/logs/.gitkeep
!**/EXPORTED_OBJECTS/.gitkeep

# PyInstaller artifacts
**/build/**
**/dist/**
**/*.spec

# OS/editor noise
.DS_Store
Thumbs.db
